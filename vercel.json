{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/orchestrate",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/jobs",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/worker/intelligence_snapshot",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/worker/intelligence_embed",
      "schedule": "*/20 * * * *"
    },
    {
      "path": "/api/cron/workers/health",
      "schedule": "0 */6 * * *"
    }
  ]
}
