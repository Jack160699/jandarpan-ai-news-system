{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/worker/ingest",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/cluster",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/orchestrate",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/revalidate",
      "schedule": "*/20 * * * *"
    }
  ]
}