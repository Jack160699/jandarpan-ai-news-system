{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/fetch-news",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/worker/editorial_generate",
      "schedule": "30 */4 * * *"
    },
    {
      "path": "/api/cron/jobs",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/revalidate",
      "schedule": "0 3 * * *"
    }
  ]
}
